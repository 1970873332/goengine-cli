{
    "js/ts.tsdk.path": "node_modules/typescript/lib",
    "js/ts.tsdk.promptToUseWorkspaceVersion": true,
    "files.associations": {
        "*.wk": "typescript",
        "*_packed.tsx": "xml"
    },
    "files.exclude": {
        // "lib": true,
        // "preset": true,
        // "config": true,
        // "package": true,
        // "declares": true,
        // "node_modules": true
    },
    "editor.quickSuggestions": {
        "strings": true
    },
    "explorer.fileNesting.enabled": true,
    "explorer.fileNesting.expand": false,
    "explorer.fileNesting.patterns": {
        "vite.config.*": "*.env, .env.*, tsconfig.*",
        "package.json": "index.html, .babelrc, .prettierrc, .gitignore, .gitattributes, *.toml, *.json, *.yaml, *.lock"
    },
    "liveServer.settings.port": 5500,
    "tailwindCSS.classFunctions": ["clsx"],
    "tailwindCSS.classAttributes": ["class", "className"]
}
