{
    "compilerOptions": {
        "target": "ESNext",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "strict": true,
        "incremental": true,
        "allowSyntheticDefaultImports": true,
        "experimentalDecorators": true,
        "emitDecoratorMetadata": true,
        "resolveJsonModule": true,
        "esModuleInterop": true,
        "allowJs": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "jsx": "preserve",
        "baseUrl": ".",
        "outDir": "dist",
        "composite": true,
        "declaration": true,
        "declarationDir": "dist/types",
        "paths": {
            "@vuee/*": [
                "package/vue/src/*"
            ],
            "@react/*": [
                "package/react/src/*"
            ],
            "@angularr/*": [
                "package/angular/src/*"
            ],
            "@core/*": [
                "package/core/src/*"
            ],
            "@web/*": [
                "package/web/src/*"
            ],
            "@webgl/*": [
                "package/webgl/src/*"
            ],
            "@canvas/*": [
                "package/canvas/src/*"
            ],
            "@service/*": [
                "package/service/src/*"
            ],
            "@electron/*": [
                "package/electron/src/*"
            ],
            "@electrobun": [
                "package/electrobun/src/*"
            ],
            "static/*": [
                "public/static/*"
            ],
            "@/*": [
                "./*"
            ]
        },
        "plugins": [
            {
                "name": "typescript-plugin-css-modules"
            }
        ],
        "types": [
            "node"
        ],
        "typeRoots": [
            "node_modules/@types"
        ]
    },
    "include": [
        "**/*.js",
        "**/*.ts",
        "**/*.jsx",
        "**/*.tsx",
        "**/*.vue",
        "**/*.json"
    ],
    "exclude": [
        "dist",
        "build",
        "public",
        "node_modules"
    ]
}