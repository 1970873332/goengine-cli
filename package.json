{
    "name": "@goengine/cli",
    "version": "0.1.0",
    "description": "Hello cli",
    "author": "Mr.Rui",
    "license": "MIT",
    "type": "module",
    "private": true,
    "workspaces": [
        "package/*",
        "services/*",
        "webs/*"
    ],
    "engines": {
        "node": ">=24.0.0",
        "npm": ">=11.0.0"
    },
    "userData": {
        "title": "Welcome to GoEngine",
        "tsconfig": "tsconfig.json",
        "out": "dist/out",
        "app": {
            "web": "webs",
            "service": "services"
        },
        "ssl": {
            "name": "dev",
            "static": "public/ssl"
        },
        "release": {
            "compose": "dist/compose"
        },
        "html": {
            "webpack": "preset/entry/webpack.html"
        },
        "web": {
            "build": "build/web"
        },
        "service": {
            "build": "build/service",
            "out": {
                "main": "index.js"
            }
        },
        "electron": {
            "dist": "dist/electron",
            "build": "build/electron",
            "input": {
                "main": "preset/entry/Electron.ts",
                "preload": "preset/entry/Preload.Electron.ts"
            },
            "out": {
                "main": "index.js",
                "preload": "preload.cjs"
            },
            "dev": {
                "index": {
                    "agreement": "http",
                    "host": "localhost",
                    "port": 8080
                }
            },
            "mirror": "https://npmmirror.com/mirrors/electron/"
        }
    },
    "scripts": {
        "ncu": "ncu -u",
        "test": "vue-tsc --noEmit",
        "type": "vue-tsc --declaration --emitDeclarationOnly",
        "tsup": "npx tsup --config config/tsup.ts",
        "clean:dist": "rimraf dist",
        "clean:build": "rimraf build",
        "clean:out": "npm run clean:dist & npm run clean:build",
        "clean:ssl": "rimraf public/ssl",
        "clean:lock": "rimraf package-lock.json pnpm-lock.yaml",
        "clean:modules": "tsx lib/clean/modules.ts",
        "clean:depend": "npm run clean:lock && npm run clean:modules",
        "install:all": "npx tsx lib/install.ts",
        "format": "prettier --write \"**/*.{js,jsx,ts,tsx,vue,css,scss,html,json,md}\" \"!**/*_packed.tsx\"",
        "vite:serve": "cross-env NODE_ENV=development tsx lib/web/serve.vite.ts",
        "vite:build": "cross-env NODE_ENV=production tsx lib/web/build.vite.ts",
        "serve:web": "cross-env NODE_ENV=development tsx lib/web/serve.ts",
        "build:web": "cross-env NODE_ENV=production tsx lib/web/build.ts",
        "serve:node": "cross-env NODE_ENV=development tsx lib/service/serve.ts",
        "build:node": "cross-env NODE_ENV=production tsx lib/service/build.ts",
        "dev:electron": "tsx lib/electron/dev.ts",
        "build:electron": "tsx lib/electron/build.ts",
        "out:electron": "tsx lib/electron/out.ts",
        "start:electron": "npm run build:electron && npm run dev:electron",
        "mon:electron": "nodemon --exec npm run start:electron",
        "serve:chii": "tsx lib/debug/chii/serve.ts -p 3000",
        "release:compose": "tsx lib/release/compose.ts",
        "create:web": "tsx lib/create/web.ts"
    },
    "dependencies": {
        "@inquirer/prompts": "^8.3.0",
        "chii": "^1.15.5",
        "commander": "^14.0.2",
        "eruda": "^3.4.3",
        "inquirer-file-selector": "^1.0.1"
    },
    "devDependencies": {
        "@babel/core": "^7.28.5",
        "@babel/plugin-transform-optional-chaining": "^7.28.5",
        "@babel/plugin-transform-runtime": "^7.28.5",
        "@babel/preset-env": "^7.28.5",
        "@babel/preset-react": "^7.28.5",
        "@babel/runtime": "^7.28.4",
        "@swc/core": "^1.15.3",
        "@tailwindcss/postcss": "^4.1.17",
        "@tailwindcss/vite": "^4.1.17",
        "@types/file-saver": "^2.0.7",
        "@types/node": "^24.10.1",
        "@types/react": "^19.2.6",
        "@types/react-dom": "^19.2.3",
        "@types/webpack-bundle-analyzer": "^4.7.0",
        "@vitejs/plugin-react": "^5.1.1",
        "@vitejs/plugin-vue": "^6.0.2",
        "@vue/compiler-sfc": "^3.5.25",
        "babel-loader": "^10.0.0",
        "cross-env": "^10.1.0",
        "css-loader": "^7.1.2",
        "css-minimizer-webpack-plugin": "^8.0.0",
        "electron-builder": "^26.0.12",
        "esbuild": "^0.27.0",
        "file-loader": "^6.2.0",
        "html-webpack-plugin": "^5.6.5",
        "mini-css-extract-plugin": "^2.9.4",
        "nodemon": "^3.1.11",
        "npm-check-updates": "^19.1.2",
        "path-browserify": "^1.0.1",
        "postcss": "^8.5.6",
        "postcss-loader": "^8.2.0",
        "prettier": "^3.7.4",
        "rimraf": "^6.1.2",
        "sass-loader": "^16.0.6",
        "selfsigned": "^4.0.0",
        "style-loader": "^4.0.0",
        "tailwindcss": "^4.1.17",
        "terser-webpack-plugin": "^5.3.14",
        "ts-loader": "^9.5.4",
        "ts-shader-loader": "^2.0.2",
        "tsup": "^8.5.1",
        "tsx": "^4.20.6",
        "typescript": "^5.9.3",
        "typescript-plugin-css-modules": "^5.2.0",
        "vite": "^7.2.4",
        "vite-plugin-html": "^3.2.2",
        "vue-loader": "^17.4.2",
        "vue-tsc": "^3.1.8",
        "webpack": "^5.103.0",
        "webpack-bundle-analyzer": "^5.0.1",
        "webpack-cli": "^6.0.1",
        "webpack-dev-server": "^5.2.2",
        "worker-loader": "^3.0.8"
    }
}